<%- include('partials/header') %>

<div class="container" style="padding-top: 100px;">
  <div class="text-center">
    <div style="margin-bottom: 2rem;">
      <i class="fas fa-shield-check brand-icon" style="font-size: 4rem; color: var(--color-accent-primary);"></i>
    </div>

    <h1 style="margin-bottom: 1rem; color: var(--color-gold-primary);">
      <i class="fas fa-unlock" style="margin-right: 0.5rem;"></i>
      Access Granted
    </h1>

    <p style="font-size: 1.25rem; color: var(--color-text-secondary); max-width: 600px; margin: 0 auto 2rem;">
      You've successfully authenticated to the Secrets Vault.
    </p>

    <hr style="margin: 2rem auto; max-width: 300px;">

    <div class="card" style="max-width: 600px; margin: 0 auto 2rem; text-align: left;">
      <div class="card-body" style="text-align: center;">
        <i class="fas fa-user-secret" style="font-size: 3rem; color: var(--color-accent-primary); margin-bottom: 1rem;"></i>
        <p style="font-size: 1.5rem; color: var(--color-text-primary); margin: 1rem 0;">
          Welcome to your secure vault
        </p>
        <p style="color: var(--color-text-muted);">
          Your secrets are protected with enterprise-grade encryption.
        </p>
      </div>
    </div>

    <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
      <a href="/logout" class="btn btn-dark" style="padding: 1rem 2rem;">
        <i class="fas fa-sign-out-alt" style="margin-right: 0.5rem;"></i>
        Logout
      </a>
      <a href="/submit" class="btn btn-primary" style="padding: 1rem 2rem;">
        <i class="fas fa-plus" style="margin-right: 0.5rem;"></i>
        Submit a Secret
      </a>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
