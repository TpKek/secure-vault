<%- include('partials/header') %>

<main id="main-content" class="container secrets-padding">
  <div class="text-center">
    <i class="fas fa-shield-check brand-icon icon-2xl text-accent mb-2" aria-hidden="true"></i>

    <h1 class="mb-2 text-gold">
      <i class="fas fa-unlock" aria-hidden="true"></i>
      Access Granted
    </h1>

    <p class="text-xl text-secondary mb-3 max-width-md m-auto">
      You've successfully authenticated to the Secrets Vault.
    </p>

    <hr class="hr--sm">

    <div class="card mb-3 secrets-card">
      <div class="text-center">
        <i class="fas fa-user-secret icon-xl text-accent mb-2" aria-hidden="true"></i>
        <p class="text-2xl text-primary" style="margin: 1rem 0;">
          Welcome to your secure vault
        </p>
        <p class="text-muted">
          Your secrets are protected with enterprise-grade encryption.
        </p>
      </div>
    </div>

    <div class="flex-center flex-wrap gap-md mt-4" style="width: 100%;">
      <a href="/logout" class="btn btn-dark">
        <i class="fas fa-sign-out-alt" aria-hidden="true"></i>
        Logout
      </a>
      <a href="/submit" class="btn btn-primary">
        <i class="fas fa-plus" aria-hidden="true"></i>
        Submit a Secret
      </a>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
