<%- include('partials/header') %>

<main id="main-content" class="page-container--sm">
  <div class="container">
    <div class="row">
      <div class="col-sm-8 m-auto">
        <div class="card">
          <div class="card-body">
            <div class="text-center mb-4">
              <i class="fas fa-user-plus brand-icon icon-xl text-gold mb-2" aria-hidden="true"></i>
              <h1 class="mb-1">Create Account</h1>
              <p class="text-muted" style="margin: 0;">Join the vault today</p>
            </div>

            <!-- Makes POST request to /register route -->
            <form action="/register" method="POST">
              <div class="form-group">
                <label for="email">
                  <i class="fas fa-envelope form-icon form-icon--gold" aria-hidden="true"></i>
                  Email Address
                </label>
                <input type="email" class="form-control" id="email" name="username" placeholder="Enter your email…" required autocomplete="email">
              </div>

              <div class="form-group">
                <label for="password">
                  <i class="fas fa-lock form-icon form-icon--gold" aria-hidden="true"></i>
                  Password
                </label>
                <input type="password" class="form-control" id="password" name="password" placeholder="Min 8 characters" required autocomplete="new-password">
                <small class="text-muted" style="display: block; margin-top: 0.5rem;">
                  Must be 8-20 characters with letters, numbers, and special characters
                </small>
              </div>

              <button type="submit" class="btn btn-gold w-100 p-3 mt-2">
                <i class="fas fa-user-plus" aria-hidden="true"></i>
                Create Account
              </button>
            </form>

            <div class="text-center mt-4">
              <p class="text-muted" style="margin: 0;">
                Already have an account?
                <a href="/login" class="text-accent" style="font-weight: 600;">
                  Login here
                </a>
              </p>
            </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
