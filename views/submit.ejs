<%- include('partials/header') %>

<main id="main-content" class="page-container--sm">
  <div class="container">
    <div class="row">
      <div class="col-sm-8 m-auto">
        <div class="card">
          <div class="card-body">
            <div class="text-center mb-4">
              <i class="fas fa-paper-plane brand-icon icon-xl text-accent mb-2" aria-hidden="true"></i>
              <h1 class="mb-1">Submit a Secret</h1>
              <p class="text-muted" style="margin: 0;">Share anonymously with the world</p>
            </div>

            <form action="/submit" method="POST">
              <div class="form-group">
                <label for="secret">
                  <i class="fas fa-user-secret form-icon" aria-hidden="true"></i>
                  Your Secret
                </label>
                <input type="text" class="form-control text-center" id="secret" name="secret" placeholder="What's your secret?…" required>
              </div>

              <button type="submit" class="btn btn-primary w-100 p-3 mt-2">
                <i class="fas fa-paper-plane" aria-hidden="true"></i>
                Submit Secret
              </button>
            </form>

            <div class="text-center mt-4">
              <a href="/secrets" class="back-link">
                <i class="fas fa-arrow-left" aria-hidden="true"></i>
                Back to Vault
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
