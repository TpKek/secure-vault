<%- include('partials/header') %>

<div class="container" style="padding-top: 100px;">
  <div class="row">
    <div class="col-sm-8" style="margin: 0 auto; float: none;">
      <div class="card">
        <div class="card-body">
          <div class="text-center" style="margin-bottom: 2rem;">
            <i class="fas fa-paper-plane brand-icon" style="font-size: 3rem; color: var(--color-accent-primary); margin-bottom: 1rem;"></i>
            <h1 style="margin-bottom: 0.5rem;">Submit a Secret</h1>
            <p style="color: var(--color-text-muted); margin: 0;">Share anonymously with the world</p>
          </div>

          <form action="/submit" method="POST">
            <div class="form-group">
              <label for="secret">
                <i class="fas fa-secret" style="margin-right: 0.5rem; color: var(--color-accent-primary);"></i>
                Your Secret
              </label>
              <input type="text" class="form-control text-center" name="secret" placeholder="What's your secret?" required>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%; padding: 1rem; margin-top: 1rem;">
              <i class="fas fa-paper-plane" style="margin-right: 0.5rem;"></i>
              Submit Secret
            </button>
          </form>

          <div class="text-center" style="margin-top: 1.5rem;">
            <a href="/secrets" style="color: var(--color-text-muted);">
              <i class="fas fa-arrow-left" style="margin-right: 0.5rem;"></i>
              Back to Vault
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
