<%- include('partials/header') %>

<main id="main-content" class="page-container">
  <div class="container text-center">
    <div class="mb-4">
      <i class="fas fa-shield-halved brand-icon icon-3xl text-accent" aria-hidden="true"></i>
    </div>

    <h1 class="mb-3 text-gradient">
      SECRETS VAULT
    </h1>

    <p class="text-xl text-secondary mb-4 max-width-md m-auto">
      Your secure authentication platform. Store and share your secrets with enterprise-grade security.
    </p>

    <hr class="hr--sm">

    <div class="flex-center flex-wrap gap-md mb-5">
      <a href="/register" class="btn btn-gold">
        <i class="fas fa-user-plus" aria-hidden="true"></i>
        Create Account
      </a>
      <a href="/login" class="btn btn-primary">
        <i class="fas fa-sign-in-alt" aria-hidden="true"></i>
        Login
      </a>
    </div>

    <div class="flex-center flex-wrap gap-xl mt-5">
      <div class="feature-box">
        <i class="fas fa-lock feature-box__icon icon-lg text-accent" aria-hidden="true"></i>
        <p class="feature-box__text">Encrypted</p>
      </div>
      <div class="feature-box">
        <i class="fas fa-user-shield feature-box__icon icon-lg text-gold" aria-hidden="true"></i>
        <p class="feature-box__text">Secure Auth</p>
      </div>
      <div class="feature-box">
        <i class="fas fa-database feature-box__icon icon-lg text-accent" aria-hidden="true"></i>
        <p class="feature-box__text">PostgreSQL</p>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
