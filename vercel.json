{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "secrets-vault",
  "builds": [
    {
      "src": "app.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.js"
    }
  ],
  "env": {
    "SUPABASE_URL": "NEXT_PUBLIC_SUPABASE_URL",
    "SUPABASE_ANON_KEY": "NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY"
  },
  "framework": null
}
